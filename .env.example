# SDR Jarvis — Environment Variables
# Copy this file to .env.local and fill in your values

# ── LLM Provider ────────────────────────────────────
# Default: OpenAI. To switch to Grok/xAI, set LLM_PROVIDER=xai and add XAI_API_KEY
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=xai
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ──────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev
REPLY_TO_EMAIL=you@yourdomain.com

# ── Google Custom Search (for research agent) ───────
# Free: 100 queries/day. Setup: https://programmablesearchengine.google.com
GOOGLE_SEARCH_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SEARCH_CX=xxxxxxxxxxxxxxxxx

# ── X / Twitter API (for lead discovery) ─────────────
# Free: 1,500 reads/month. Setup: https://developer.x.com
X_BEARER_TOKEN=

# ── Google Calendar OAuth (optional) ────────────────
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPx-xxxxxxxxxxxxxxxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── LangSmith (observability — optional) ────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=sdr-jarvis

# ── Stripe Billing ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend Webhooks ─────────────────────────────────
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron Job ────────────────────────────────────────
CRON_SECRET=your-random-cron-secret-here

# ── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
